# BirdWeatherViz3 Environment Variables
# Version: 1.0.0
#
# Copy this file to .env and update values for your environment

# ========================================
# Application Settings
# ========================================
APP_NAME=BirdWeatherViz3
DEBUG=false

# ========================================
# API Settings
# ========================================
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# Database
# ========================================
# SQLite (default, single file)
DATABASE_URL=sqlite:///./data/db/birdweather.db

# PostgreSQL (optional, for larger deployments)
# DATABASE_URL=postgresql://user:password@localhost:5432/birdweather

# ========================================
# Security
# ========================================
# IMPORTANT: Change these in production!
SECRET_KEY=CHANGE-ME-USE-RANDOM-STRING-HERE
JWT_SECRET=CHANGE-ME-USE-RANDOM-STRING-HERE
CONFIG_PASSWORD=changeme

# Generate random secrets with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# ========================================
# CORS (Cross-Origin Resource Sharing)
# ========================================
# WARNING: Never use ["*"] in production!
# For local development:
CORS_ORIGINS=["http://localhost:3001", "http://127.0.0.1:3001"]
# For production, specify your domain:
# CORS_ORIGINS=["https://yourdomain.com"]

# ========================================
# Auto-Update Settings
# ========================================
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_INTERVAL=3600  # seconds (3600 = 1 hour)

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_FILE_PATH=./data/logs/app.log

# ========================================
# Data Directory (base path for image cache, etc.)
# ========================================
# For local development use relative path; Docker uses /app/data
DATA_DIR=./data

# ========================================
# File Uploads
# ========================================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes

# ========================================
# Wikimedia Integration
# ========================================
WIKIMEDIA_USER_AGENT=BirdWeatherViz3/1.0
WIKIMEDIA_EMAIL=your-email@example.com

# ========================================
# Pagination
# ========================================
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=1000
