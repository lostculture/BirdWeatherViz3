# BirdWeatherViz3 Public Instance Environment Variables
# Copy this file to .env.public and configure with your values
#
# IMPORTANT: Never commit .env.public to version control!

# ========================================
# Security - CHANGE THESE VALUES!
# ========================================

# Configuration page password (minimum 8 characters, use a strong password!)
CONFIG_PASSWORD=change-this-to-a-strong-password

# JWT secret for token signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========================================
# CORS - Cross-Origin Resource Sharing
# ========================================
# Set to your public domain (must match your Cloudflare tunnel hostname)
CORS_ORIGINS=["https://yourdomain.com"]

# ========================================
# Cloudflare Tunnel
# ========================================

# Get this from Cloudflare Zero Trust Dashboard:
# Networks > Tunnels > Create Tunnel > Copy Token
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
